<div class="min-h-screen bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900 py-12 px-4">
  <div class="max-w-lg mx-auto">
    <h1 class="text-3xl font-bold text-white tracking-tight mb-8">My Profile</h1>

    <% if flash[:notice] %>
      <div class="mb-6 rounded-lg bg-green-500/10 border border-green-500/20 px-4 py-3 text-green-400 text-sm">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="mb-6 rounded-lg bg-red-500/10 border border-red-500/20 px-4 py-3 text-red-400 text-sm flex items-center gap-2">
        <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/></svg>
        <%= flash[:alert] %>
      </div>
    <% end %>

    <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-7 shadow-2xl space-y-6">
      <div class="space-y-3">
        <div class="flex items-center justify-between py-2 border-b border-white/10">
          <span class="text-slate-400 text-sm">Name</span>
          <span class="text-white text-sm font-medium"><%= Current.user.name %></span>
        </div>
        <div class="flex items-center justify-between py-2 border-b border-white/10">
          <span class="text-slate-400 text-sm">Email</span>
          <span class="text-white text-sm font-medium"><%= Current.user.email_address %></span>
        </div>
        <div class="flex items-center justify-between py-2 border-b border-white/10">
          <span class="text-slate-400 text-sm">Admin</span>
          <span class="text-sm font-medium <%= Current.user.is_admin? ? 'text-purple-300' : 'text-slate-400' %>">
            <%= Current.user.is_admin? ? "Yes" : "No" %>
          </span>
        </div>
        <div class="flex items-center justify-between py-2">
          <span class="text-slate-400 text-sm">Member since</span>
          <span class="text-white text-sm font-medium"><%= Current.user.created_at.strftime("%B %d, %Y") %></span>
        </div>
      </div>

      <div>
        <h2 class="text-lg font-semibold text-white mb-4">Passkeys</h2>
        <% if Current.user.webauthn_credentials.any? %>
          <ul class="space-y-2 mb-4">
            <% Current.user.webauthn_credentials.each do |credential| %>
              <li class="flex items-center justify-between rounded-lg bg-white/5 border border-white/10 px-4 py-3">
                <div>
                  <p class="text-white text-sm font-medium"><%= credential.nickname %></p>
                  <p class="text-slate-500 text-xs mt-0.5">Added <%= credential.created_at.strftime("%B %d, %Y") %></p>
                </div>
                <%= button_to "Remove", webauthn_credential_path(credential), method: :delete,
                      class: "rounded-lg border border-red-500/30 bg-red-500/10 hover:bg-red-500/20 text-red-400 text-xs font-medium py-1.5 px-3 transition cursor-pointer",
                      data: { confirm: "Remove this passkey?" } %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-slate-400 text-sm mb-4">No passkeys registered.</p>
        <% end %>

        <button id="register-passkey"
                data-controller="passkey-register"
                data-passkey-register-options-url-value="<%= new_registration_options_webauthn_credentials_path %>"
                class="w-full rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 text-slate-300 font-medium py-2.5 px-4 text-sm transition flex items-center justify-center gap-2 cursor-pointer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add Passkey
        </button>
      </div>

      <% if Current.user.is_admin? %>
        <div>
          <h2 class="text-lg font-semibold text-white mb-3">Admin</h2>
          <%= link_to "Mission Control Dashboard", "/jobs",
                class: "inline-block rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-semibold py-2.5 px-4 text-sm transition" %>
        </div>
      <% end %>

      <div class="pt-2 border-t border-white/10">
        <%= button_to "Sign out", session_path, method: :delete,
              class: "w-full rounded-lg border border-white/20 bg-white/5 hover:bg-white/10 text-slate-300 font-medium py-2.5 px-4 text-sm transition cursor-pointer" %>
      </div>
    </div>
  </div>
</div>
