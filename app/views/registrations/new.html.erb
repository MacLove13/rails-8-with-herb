<div class="min-h-screen bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900 flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-white tracking-tight">Create account</h1>
      <p class="text-slate-400 mt-2">Join us today — it's free</p>
    </div>

    <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 shadow-2xl">
      <%= form_with model: @user, url: register_path do |form| %>
        <% if @user.errors.any? %>
          <div class="mb-5 rounded-lg bg-red-500/10 border border-red-500/20 px-4 py-3 text-red-400 text-sm">
            <p class="font-semibold mb-1"><%= pluralize(@user.errors.count, "error") %> prevented this account from being saved:</p>
            <ul class="list-disc list-inside space-y-0.5">
              <% @user.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-5">
          <div>
            <%= form.label :name, class: "block text-sm font-medium text-slate-300 mb-1.5" %>
            <%= form.text_field :name,
                  required: true, autofocus: true,
                  class: "w-full rounded-lg bg-white/5 border border-white/10 text-white placeholder-slate-500 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition",
                  placeholder: "Your full name" %>
          </div>

          <div>
            <%= form.label :email_address, "Email address", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
            <%= form.email_field :email_address,
                  required: true,
                  class: "w-full rounded-lg bg-white/5 border border-white/10 text-white placeholder-slate-500 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition",
                  placeholder: "you@example.com" %>
          </div>

          <div>
            <%= form.label :password, class: "block text-sm font-medium text-slate-300 mb-1.5" %>
            <%= form.password_field :password,
                  required: true,
                  class: "w-full rounded-lg bg-white/5 border border-white/10 text-white placeholder-slate-500 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition",
                  placeholder: "••••••••" %>
          </div>

          <div>
            <%= form.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
            <%= form.password_field :password_confirmation,
                  required: true,
                  class: "w-full rounded-lg bg-white/5 border border-white/10 text-white placeholder-slate-500 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition",
                  placeholder: "••••••••" %>
          </div>

          <div class="pt-1">
            <%= form.submit "Create account",
                  class: "w-full rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-semibold py-2.5 px-4 text-sm transition cursor-pointer focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 focus:ring-offset-slate-900" %>
          </div>
        </div>
      <% end %>

      <div class="mt-6 text-center text-sm">
        <span class="text-slate-400">Already have an account?</span>
        <%= link_to "Sign in", new_session_path, class: "text-purple-400 hover:text-purple-300 transition ml-1" %>
      </div>
    </div>
  </div>
</div>
