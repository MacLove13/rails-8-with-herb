<div class="container">
  <div class="auth-card">
    <h1>Create Account</h1>
    <%= form_with model: @user, url: register_path do |form| %>
      <% if @user.errors.any? %>
        <div class="error-messages">
          <h2><%= pluralize(@user.errors.count, "error") %> prevented this account from being saved:</h2>
          <ul>
            <% @user.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="field">
        <%= form.label :name %>
        <%= form.text_field :name, required: true, autofocus: true %>
      </div>

      <div class="field">
        <%= form.label :email_address, "Email" %>
        <%= form.email_field :email_address, required: true %>
      </div>

      <div class="field">
        <%= form.label :password %>
        <%= form.password_field :password, required: true %>
      </div>

      <div class="field">
        <%= form.label :password_confirmation, "Confirm Password" %>
        <%= form.password_field :password_confirmation, required: true %>
      </div>

      <div class="actions">
        <%= form.submit "Create Account", class: "btn" %>
      </div>

      <div class="auth-links">
        Already have an account? <%= link_to "Sign in", new_session_path %>
      </div>
    <% end %>
  </div>
</div>
