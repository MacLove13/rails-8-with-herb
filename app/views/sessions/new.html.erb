<div class="min-h-screen bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900 flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-white tracking-tight">Welcome back</h1>
      <p class="text-slate-400 mt-2">Sign in to your account to continue</p>
    </div>

    <% if flash[:alert] %>
      <div class="mb-4 rounded-lg bg-red-500/10 border border-red-500/20 px-4 py-3 text-red-400 text-sm flex items-center gap-2">
        <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/></svg>
        <%= flash[:alert] %>
      </div>
    <% end %>

    <% if flash[:notice] %>
      <div class="mb-4 rounded-lg bg-green-500/10 border border-green-500/20 px-4 py-3 text-green-400 text-sm">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 shadow-2xl">
      <%= form_with url: session_path do |form| %>
        <div class="space-y-5">
          <div>
            <%= form.label :email_address, "Email address", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
            <%= form.email_field :email_address,
                  required: true, autofocus: true,
                  autocomplete: "username",
                  value: params[:email_address],
                  class: "w-full rounded-lg bg-white/5 border border-white/10 text-white placeholder-slate-500 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition",
                  placeholder: "you@example.com" %>
          </div>

          <div>
            <%= form.label :password, class: "block text-sm font-medium text-slate-300 mb-1.5" %>
            <%= form.password_field :password,
                  required: true,
                  autocomplete: "current-password",
                  maxlength: 72,
                  class: "w-full rounded-lg bg-white/5 border border-white/10 text-white placeholder-slate-500 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition",
                  placeholder: "••••••••" %>
          </div>

          <div class="pt-1">
            <%= form.submit "Sign in",
                  class: "w-full rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-semibold py-2.5 px-4 text-sm transition cursor-pointer focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 focus:ring-offset-slate-900" %>
          </div>
        </div>
      <% end %>

      <div class="mt-6">
        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-white/10"></div>
          </div>
          <div class="relative flex justify-center text-xs text-slate-500">
            <span class="bg-transparent px-3">or continue with</span>
          </div>
        </div>

        <div class="mt-4">
          <button id="passkey-login"
                  data-controller="passkey-authenticate"
                  data-passkey-authenticate-options-url-value="<%= new_webauthn_authentication_options_path %>"
                  data-passkey-authenticate-authenticate-url-value="<%= webauthn_authentication_path %>"
                  class="w-full rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 text-slate-300 font-medium py-2.5 px-4 text-sm transition flex items-center justify-center gap-2 cursor-pointer">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
            Sign in with Passkey
          </button>
        </div>
      </div>

      <div class="mt-6 flex items-center justify-between text-sm">
        <%= link_to "Forgot password?", new_password_path, class: "text-purple-400 hover:text-purple-300 transition" %>
        <%= link_to "Create an account", register_path, class: "text-slate-400 hover:text-white transition" %>
      </div>
    </div>
  </div>
</div>
